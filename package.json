{
  "name": "ovgs",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Gestão de Ordens de Venda com Next.js, React Query, Redux Saga e API REST mockada.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
